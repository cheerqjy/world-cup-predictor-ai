{
  "name": "world-cup-predictor",
  "private": true,
  "version": "1.4.1",
  "description": "2026 World Cup Predictor",
  "main": "electron/main.js",
  "author": "World Cup Predictor",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "dev:server": "node server/index.js",
    "dev:all": "node server/index.js & vite",
    "build": "vite build",
    "preview": "vite preview",
    "vercel-build": "npm run build",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder --win",
    "electron:build:dir": "npm run build && electron-builder --win --dir",
    "release": "node release.js"
  },
  "build": {
    "appId": "com.worldcup.predictor",
    "productName": "WorldCupPredictor",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "server/**/*",
      "electron/**/*",
      "data/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WorldCup Predictor",
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-Portable.${ext}"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "typescript": "~6.0.2",
    "vite": "^4.5.0"
  },
  "dependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.0",
    "cors": "^2.8.6",
    "express": "^4.21.0",
    "openai": "^6.42.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "sql.js": "^1.14.1"
  }
}
